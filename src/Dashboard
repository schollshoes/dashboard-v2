  document.getElementById('pkpi-n-skus').textContent       = kpi.n_skus.toLocaleString('it-IT');
  document.getElementById('pkpi-new-skus-pct').textContent = newSkuPct + '% nuovi vs 2025';

  // Update KPI cards — vecchie (top prodotto, fatturato top12, resi, sconto)
  const summary = PROD_SUMMARY[key] || PROD_SUMMARY['all'];
  document.getElementById('pkpi-top-name').textContent    = summary.top_name;
  document.getElementById('pkpi-top-sales').textContent   = '€' + summary.top_sales.toLocaleString('it-IT') + ' netti';
  document.getElementById('pkpi-total-sales').textContent = '€' + (summary.total_sales/1000).toFixed(0) + 'K';
  document.getElementById('pkpi-avg-ret').textContent     = summary.avg_ret + '%';
  document.getElementById('pkpi-max-ret').textContent     = summary.max_ret + '%';
  document.getElementById('pkpi-max-ret-name').textContent= summary.max_ret_name;
  document.getElementById('pkpi-avg-disc').textContent    = summary.avg_disc + '%';

  const pN=prods.map(p=>p.name), pS=prods.map(p=>p.sales), pR=prods.map(p=>p.ret);
  if(chartProd) chartProd.destroy();
  chartProd = new Chart(document.getElementById('chartProd'),{
    type:'bar',data:{labels:pN,datasets:[{label:'Net Sales',data:pS,backgroundColor:'rgba(88,166,255,.75)',borderRadius:4,borderSkipped:false}]},
    options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>`€${c.parsed.x.toLocaleString('it-IT')}`}}},scales:{x:{grid:{color:'rgba(48,54,61,.6)'},ticks:{callback:v=>'€'+(v>=1000?(v/1000).toFixed(0)+'k':v),font:{size:10}}},y:{grid:{display:false},ticks:{font:{size:10}}}}}
  });
  if(chartRet) chartRet.destroy();
  chartRet = new Chart(document.getElementById('chartRet'),{
    type:'bar',data:{labels:pN,datasets:[{label:'Tasso Reso %',data:pR,backgroundColor:pR.map(v=>v>20?'rgba(248,81,73,.7)':v>10?'rgba(210,153,34,.7)':'rgba(63,185,80,.7)'),borderRadius:4,borderSkipped:false}]},
    options:{indexAxis:'y',responsive:true,plugins:{legend:{display:false},tooltip:{...TT,callbacks:{label:c=>`${c.parsed.x}%`}}},scales:{x:{grid:{color:'rgba(48,54,61,.6)'},ticks:{callback:v=>v+'%',font:{size:10}}},y:{grid:{display:false},ticks:{font:{size:10}}}}}
  });
  const ptb=document.getElementById('prodTbody');
  if(ptb){ptb.innerHTML='';prods.forEach(p=>{const rc=p.ret>20?'color:#f85149':p.ret>10?'color:#d29922':'color:#3fb950';const dc=p.disc>5?'color:#d29922':'color:#7d8590';ptb.innerHTML+=`<tr><td>${p.name}</td><td class="num">€${p.sales.toLocaleString('it-IT')}</td><td class="num">${p.qty}</td><td class="num" style="color:#58a6ff">€${p.avg_price.toFixed(2)}</td><td class="num" style="${rc}">${p.ret}%</td><td class="num" style="${dc}">${p.disc}%</td></tr>`;});}
}

// ── SUMMARY TABLE ──
function buildSummaryTable(rows, tbodyId) {
  const tbody = document.getElementById(tbodyId);
  if (!tbody) return;
  tbody.innerHTML = '';
  rows.forEach(r => {
    const gd = parseFloat(r.gross_delta), od = parseFloat(r.orders_delta), sd = parseFloat(r.sess_delta);
    tbody.innerHTML += `<tr>
      <td>${r.period}</td>
      <td class="num">${fmtK(r.sess26)}</td>
      <td class="num col-muted">${fmtK(r.sess25)}</td>
      <td><span class="tag ${deltaClass(sd)}">${sd<0?'▼':'▲'}${Math.abs(sd).toFixed(1)}%</span></td>
      <td class="num" style="color:#3fb950">${r.cvr26}%</td>
      <td class="num col-muted">${r.cvr25}%</td>
      <td class="num">${r.orders26.toLocaleString()}</td>
      <td class="num col-muted">${r.orders25.toLocaleString()}</td>
      <td><span class="tag ${deltaClass(od)}">${od>0?'▲':'▼'}${Math.abs(od).toFixed(0)}%</span></td>
      <td class="num" style="color:#58a6ff">€${r.aov26}</td>
      <td class="num">€${(r.gross26/1000).toFixed(0)}k</td>
      <td class="num col-muted">€${(r.gross25/1000).toFixed(0)}k</td>
      <td><span class="tag ${deltaClass(gd)}">${gd>0?'▲':'▼'}${Math.abs(gd).toFixed(0)}%</span></td>
      <td class="num" style="color:${r.ret_rate26>18?'#f85149':r.ret_rate26>14?'#d29922':'#3fb950'}">${r.ret_rate26}%</td>
    </tr>`;
  });
}

function buildTrafficoTable(rows) {
  const tbody = document.getElementById('trafficoTbody');
  if (!tbody) return;
  tbody.innerHTML = '';
  rows.forEach(r => {
    const sd = parseFloat(r.sess_delta), od = parseFloat(r.orders_delta);
    tbody.innerHTML += `<tr>
      <td>${r.period}</td>
      <td class="num">${fmtK(r.sess26)}</td>
      <td class="num col-muted">${fmtK(r.sess25)}</td>
      <td><span class="tag ${deltaClass(sd)}">${sd<0?'▼':'▲'}${Math.abs(sd).toFixed(0)}%</span></td>
      <td class="num" style="color:#3fb950">${r.cvr26}%</td>
      <td class="num col-muted">${r.cvr25}%</td>
      <td class="num" style="color:#58a6ff">€${r.aov26}</td>
      <td class="num col-muted">€${r.aov25}</td>
      <td class="num">${r.orders26.toLocaleString()}</td>
      <td class="num col-muted">${r.orders25.toLocaleString()}</td>
      <td><span class="tag ${deltaClass(od)}">${od>0?'▲':'▼'}${Math.abs(od).toFixed(0)}%</span></td>
    </tr>`;
  });
}

// ── FILTER ──
function applyFilter(period, btn) {
  currentFilter = period;
  document.querySelectorAll('.fp').forEach(b => b.classList.remove('active','all'));
  btn.classList.add('active');
  updateAll();
}

function updateAll() {
  updateKPIs();
  const rows = currentFilter === 'all' ? MONTHLY : getFilteredData();
  buildSummaryTable(currentFilter === 'all' ? MONTHLY : rows, 'summaryTbody');
  buildSummaryTable(currentFilter === 'all' ? WEEKLY : rows, 'summaryTbody');
  // rebuild summary with correct rows
  const sumRows = currentFilter === 'all' ? MONTHLY : rows;
  buildSummaryTable(sumRows, 'summaryTbody');
  buildTrafficoTable(currentFilter === 'all' ? MONTHLY : rows);
  if (currentTab === 'vendite') initChartsVendite();
  else if (currentTab === 'traffico') initChartsTraffic();
  else if (currentTab === 'prodotti') initChartsProdotti();
}

// ── MAIN TAB SWITCH ──
function switchMainTab(tab, btn) {
  currentTab = tab;
  document.querySelectorAll('.tab-panel').forEach(p => p.classList.remove('active'));
  document.querySelectorAll('.tnav-btn').forEach(b => b.classList.remove('active'));
  document.getElementById('tab-'+tab).classList.add('active');
  btn.classList.add('active');
  setTimeout(() => {
    if (tab === 'vendite') initChartsVendite();
    else if (tab === 'traffico') initChartsTraffic();
    else if (tab === 'canali') initChartsCanali();
    else if (tab === 'prodotti') initChartsProdotti();
  }, 30);
}

// ── INIT ──
buildSummaryTable(MONTHLY, 'summaryTbody');
buildTrafficoTable(MONTHLY);
initChartsVendite();
</script>
