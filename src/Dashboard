  displayColors:true, boxWidth:10, boxHeight:10
};

function fmtK(v) { return v >= 1000 ? (v/1000).toFixed(1)+'k' : v; }
function fmtEur(v) { return '€'+(v>=1000?(v/1000).toFixed(0)+'k':v); }
function deltaClass(v) { return v > 0 ? 'up' : v < 0 ? 'dn' : 'nu'; }
function deltaStr(v) { return (v > 0 ? '▲' : v < 0 ? '▼' : '') + Math.abs(v).toFixed(1) + '%'; }

// ── GET CURRENT DATA ──
function getFilteredData() {
  if (currentFilter === 'all') return MONTHLY;
  if (['Gen','Feb','Mar'].includes(currentFilter)) {
    const found = MONTHLY.find(r => r.period === currentFilter);
    return found ? [found] : MONTHLY;
  }
  const found = WEEKLY.find(r => r.period === currentFilter);
  return found ? [found] : WEEKLY;
}

function getFilteredTotals() {
  if (currentFilter === 'all') return TOTALS;
  const rows = getFilteredData();
  if (!rows.length) return TOTALS;
  if (rows.length === 1) {
    const r = rows[0];
    return {
      gross26:r.gross26, gross25:r.gross25,
      gross_delta:r.gross_delta,
      orders26:r.orders26, orders25:r.orders25,
      orders_delta:r.orders_delta,
      aov26:r.aov26, aov25:r.aov25,
      aov_delta:r.aov25 ? ((r.aov26-r.aov25)/r.aov25*100).toFixed(1) : 0,
      sess26:r.sess26, sess25:r.sess25,
      sess_delta:r.sess_delta,
      cvr26:r.cvr26, cvr25:r.cvr25,
      cvr_delta:r.cvr25 ? ((r.cvr26-r.cvr25)/r.cvr25*100).toFixed(1) : 0,
      ret_rate26:r.ret_rate26, ret25_rate:0, ret_delta:0
    };
  }
  return TOTALS;
}

// ── UPDATE KPIs ──
function updateKPIs() {
  const t = getFilteredTotals();
  // Gross
  document.getElementById('kpi-gross').textContent = '€'+Number(t.gross26).toLocaleString('it-IT');
  document.getElementById('kpi-gross-vs').textContent = 'vs €'+Number(t.gross25).toLocaleString('it-IT');
  const gt = document.getElementById('kpi-gross-tag');
  gt.className='tag '+deltaClass(t.gross_delta); gt.textContent=deltaStr(t.gross_delta);
  // Orders
  document.getElementById('kpi-orders').textContent = Number(t.orders26).toLocaleString('it-IT');
  document.getElementById('kpi-orders-vs').textContent = 'vs '+Number(t.orders25).toLocaleString('it-IT');
  const ot = document.getElementById('kpi-orders-tag');
  ot.className='tag '+deltaClass(t.orders_delta); ot.textContent=deltaStr(t.orders_delta);
  // AOV
  document.getElementById('kpi-aov').textContent = '€'+t.aov26;
  document.getElementById('kpi-aov-vs').textContent = 'vs €'+t.aov25;
  const at = document.getElementById('kpi-aov-tag');
  at.className='tag '+deltaClass(t.aov_delta); at.textContent=deltaStr(parseFloat(t.aov_delta));
  // Sessions
  document.getElementById('kpi-sess').textContent = fmtK(t.sess26);
  document.getElementById('kpi-sess-vs').textContent = 'vs '+fmtK(t.sess25);
  const st = document.getElementById('kpi-sess-tag');
  st.className='tag '+deltaClass(t.sess_delta); st.textContent=deltaStr(Math.abs(t.sess_delta));
  if(t.sess_delta<0) st.textContent='▼'+Math.abs(t.sess_delta).toFixed(1)+'%';
  // CVR
  document.getElementById('kpi-cvr').textContent = t.cvr26+'%';
  document.getElementById('kpi-cvr-vs').textContent = 'vs '+t.cvr25+'%';
  const ct = document.getElementById('kpi-cvr-tag');
  ct.className='tag '+deltaClass(t.cvr_delta); ct.textContent=deltaStr(parseFloat(t.cvr_delta));
  // Returns
  document.getElementById('kpi-ret').textContent = t.ret_rate26+'%';
  document.getElementById('kpi-ret-vs').textContent = 'vs '+t.ret25_rate+'%';
  const rt = document.getElementById('kpi-ret-tag');
  const retDir = (t.ret_rate26 < t.ret25_rate) ? 1 : -1;
  rt.className='tag '+(retDir>0?'up':'dn'); rt.textContent=(retDir>0?'▼':'▲')+Math.abs(t.ret_delta).toFixed(1)+'%';
}

// ── BUILD CHART HELPER ──
function buildBar(id, labels, ds) {
  const ctx = document.getElementById(id);
  if (!ctx) return null;
  return new Chart(ctx, {
    type: 'bar',
    data: { labels, datasets: ds },
    options: {
      responsive: true,
      interaction: { mode:'index', intersect:false },
      plugins: { legend:{display:false}, tooltip:{...TT} },
      scales: {
        x: { grid:{display:false}, ticks:{font:{size:10}} },
        y: { grid:{color:'rgba(48,54,61,.6)'}, ticks:{callback:v=>v>=1000?(v/1000).toFixed(0)+'k':v, font:{size:10}} }
      }
    }
  });
}

