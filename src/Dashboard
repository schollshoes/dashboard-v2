<!DOCTYPE html>
<html lang="it">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Sales Dashboard 2026 · Sito Diretto</title>
<script src="https://cdnjs.cloudflare.com/ajax/libs/Chart.js/4.4.0/chart.umd.min.js"></script>
<link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700&display=swap" rel="stylesheet">
<style>
  :root {
    --bg: #0d1117;
    --surface: #161b22;
    --surface2: #1c2333;
    --border: #21262d;
    --border2: #30363d;
    --text: #e6edf3;
    --muted: #7d8590;
    --muted2: #484f58;
    --green: #3fb950;
    --red: #f85149;
    --gold: #d29922;
    --blue: #58a6ff;
    --cyan: #39d353;
    --active: #1f6feb;
  }
  * { margin:0; padding:0; box-sizing:border-box; }
  body {
    background: var(--bg);
    color: var(--text);
    font-family: 'Inter', sans-serif;
    font-size: 13px;
    min-height: 100vh;
  }

  /* ── TOPBAR ── */
  .topbar {
    padding: 14px 24px 0;
    border-bottom: 1px solid var(--border);
  }
  .topbar-row1 {
    display: flex;
    align-items: flex-start;
    justify-content: space-between;
    margin-bottom: 10px;
  }
  .topbar-left {}
  .eyebrow {
    font-size: 10px;
    font-weight: 500;
    letter-spacing: .1em;
    text-transform: uppercase;
    color: var(--blue);
    margin-bottom: 4px;
  }
  .dash-title {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.4px;
  }
  .dash-sub {
    font-size: 11px;
    color: var(--muted);
    margin-top: 3px;
  }
  .dash-sub span { color: var(--gold); font-weight: 500; }

  /* Tab navigation */
  .tab-nav {
    display: flex;
    align-items: center;
    gap: 4px;
  }
  .tnav-btn {
    font-family: 'Inter', sans-serif;
    font-size: 12px;
    font-weight: 500;
    padding: 6px 14px;
    border-radius: 6px;
    border: 1px solid var(--border2);
    background: transparent;
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
    white-space: nowrap;
  }
  .tnav-btn:hover { background: var(--surface2); color: var(--text); }
  .tnav-btn.active {
    background: var(--active);
    border-color: var(--active);
    color: #fff;
    font-weight: 600;
  }
  .tnav-sep {
    width: 1px; height: 20px;
    background: var(--border2);
    margin: 0 4px;
  }

  /* ── FILTER BAR ── */
  .filterbar {
    padding: 12px 24px;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 1px solid var(--border);
    gap: 12px;
  }
  .filter-label {
    font-size: 11px;
    color: var(--muted);
    font-weight: 500;
    letter-spacing: .05em;
    text-transform: uppercase;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .filter-pills {
    display: flex;
    gap: 4px;
    flex-wrap: wrap;
  }
  .fp {
    font-size: 11.5px;
    font-weight: 500;
    padding: 4px 11px;
    border-radius: 6px;
    border: none;
    background: var(--surface2);
    color: var(--muted);
    cursor: pointer;
    transition: all .15s;
    font-family: 'Inter', sans-serif;
  }
  .fp:hover { background: var(--border2); color: var(--text); }
  .fp.active {
    background: var(--active);
    color: #fff;
    font-weight: 600;
  }
  .fp.all { background: var(--active); color: #fff; font-weight: 600; }
  .btn-period {
    font-size: 11.5px;
    font-weight: 500;
    padding: 4px 12px;
    border-radius: 6px;
    border: 1px solid var(--border2);
    background: var(--surface2);
    color: var(--text);
    cursor: pointer;
    font-family: 'Inter', sans-serif;
    white-space: nowrap;
    flex-shrink: 0;
  }
  .btn-period:hover { border-color: var(--blue); }

  /* ── KPI CARDS ── */
  .kpi-row {
    display: grid;
    grid-template-columns: repeat(6, 1fr);
    gap: 1px;
    background: var(--border);
    margin: 16px 24px;
    border-radius: 10px;
    overflow: hidden;
    border: 1px solid var(--border);
  }
  .kpi {
    background: var(--surface);
    padding: 16px 18px;
    display: flex;
    flex-direction: column;
    gap: 6px;
    transition: background .15s;
    cursor: default;
  }
  .kpi:hover { background: var(--surface2); }
  .kpi-name {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .1em;
    color: var(--muted);
  }
  .kpi-val {
    font-size: 22px;
    font-weight: 700;
    color: #fff;
    letter-spacing: -.5px;
    line-height: 1;
  }
  .kpi-vs {
    font-size: 11px;
    color: var(--muted);
    display: flex;
    align-items: center;
    gap: 6px;
  }
  .tag {
    display: inline-flex;
    align-items: center;
    gap: 2px;
    font-size: 10.5px;
    font-weight: 600;
    padding: 1px 5px;
    border-radius: 4px;
  }
  .tag.up { background: rgba(63,185,80,.15); color: var(--green); }
  .tag.dn { background: rgba(248,81,73,.15); color: var(--red); }
  .tag.nu { background: rgba(93,105,118,.15); color: var(--muted); }

  /* ── CHARTS ROW ── */
  .charts-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    margin: 0 24px 16px;
  }
  .chart-card {
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    padding: 18px 20px;
  }
  .chart-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    margin-bottom: 16px;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .ct-legend {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-left: auto;
    font-size: 10px;
    font-weight: 500;
    color: var(--muted);
  }
  .leg-dot {
    width: 8px; height: 8px;
    border-radius: 2px;
    display: inline-block;
  }

  /* ── SUMMARY TABLE ── */
  .summary-wrap {
    margin: 0 24px 24px;
    background: var(--surface);
    border: 1px solid var(--border);
    border-radius: 10px;
    overflow: hidden;
  }
  .summary-title {
    font-size: 12px;
    font-weight: 600;
    color: var(--text);
    padding: 14px 18px 10px;
    border-bottom: 1px solid var(--border);
  }
  .sum-table {
    width: 100%;
    border-collapse: collapse;
  }
  .sum-table th {
    font-size: 10px;
    font-weight: 600;
    text-transform: uppercase;
    letter-spacing: .08em;
    color: var(--muted);
    text-align: right;
    padding: 8px 14px;
    background: rgba(0,0,0,.2);
    border-bottom: 1px solid var(--border);
    white-space: nowrap;
  }
  .sum-table th:first-child { text-align: left; }
  .sum-table td {
    padding: 10px 14px;
    text-align: right;
    border-bottom: 1px solid var(--border);
    font-size: 12px;
    white-space: nowrap;
  }
  .sum-table td:first-child {
    text-align: left;
    font-weight: 600;
    color: var(--text);
  }
  .sum-table tr:last-child td { border-bottom: none; }
  .sum-table tr:hover td { background: rgba(255,255,255,.02); }
  .num { font-variant-numeric: tabular-nums; }
  .col-muted { color: var(--muted); }
  .footnote {
    font-size: 10px;
    color: var(--muted2);
    text-align: center;
    padding: 10px;
    border-top: 1px solid var(--border);
  }

  /* ── TAB PANELS ── */
  .tab-panel { display: none; }
  .tab-panel.active { display: block; }
</style>
</head>
<body>

<!-- TOPBAR -->
<div class="topbar">
